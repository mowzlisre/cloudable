{
  "name": "cloudable",
  "version": "1.0.0",
  "description": "AWS cost intelligence desktop app",
  "author": {
    "name": "Cloudable",
    "email": "contact@mowzlisre.me"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -n FRONTEND,ELECTRON -c cyan,yellow \"npm run dev:frontend\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "make": "npm run build:frontend && electron-forge make",
    "make:mac": "npm run build:frontend && electron-forge make --platform darwin",
    "make:win": "npm run build:frontend && electron-forge make --platform win32",
    "make:linux": "npm run build:frontend && electron-forge make --platform linux",
    "package": "npm run build:frontend && electron-forge package"
  },
  "dependencies": {
    "@aws-sdk/client-api-gateway": "^3.1032.0",
    "@aws-sdk/client-cloudfront": "^3.1032.0",
    "@aws-sdk/client-cloudwatch": "^3.1032.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1032.0",
    "@aws-sdk/client-cost-explorer": "^3.600.0",
    "@aws-sdk/client-dynamodb": "^3.1032.0",
    "@aws-sdk/client-ec2": "^3.600.0",
    "@aws-sdk/client-ecr": "^3.1032.0",
    "@aws-sdk/client-ecs": "^3.1032.0",
    "@aws-sdk/client-efs": "^3.1032.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.600.0",
    "@aws-sdk/client-elasticache": "^3.1032.0",
    "@aws-sdk/client-eventbridge": "^3.1032.0",
    "@aws-sdk/client-iam": "^3.1032.0",
    "@aws-sdk/client-kafka": "^3.1032.0",
    "@aws-sdk/client-kinesis": "^3.1032.0",
    "@aws-sdk/client-lambda": "^3.1032.0",
    "@aws-sdk/client-opensearch": "^3.1032.0",
    "@aws-sdk/client-organizations": "^3.1032.0",
    "@aws-sdk/client-rds": "^3.600.0",
    "@aws-sdk/client-redshift": "^3.1032.0",
    "@aws-sdk/client-route-53": "^3.1032.0",
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/client-sfn": "^3.1032.0",
    "@aws-sdk/client-sns": "^3.1032.0",
    "@aws-sdk/client-sqs": "^3.1032.0",
    "@aws-sdk/client-sts": "^3.600.0",
    "@aws-sdk/client-wafv2": "^3.1032.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "electron-store": "^8.1.0",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "wait-on": "^7.2.0"
  },
  "config": {
    "forge": "./forge.config.js"
  }
}
